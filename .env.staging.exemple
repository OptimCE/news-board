# Template for .env.staging — copy to .env.staging and fill in real values.
# Pydantic will refuse to start the service if any required key below is missing.

# ── Core ──
ENV=staging

# ── CRM Database ──
CRM_DATABASE_URL=postgresql+asyncpg://user:password@crm-db.staging.internal/optimce
CRM_DB_SSL=true

# ── LOCAL Database ──
LOCAL_DATABASE_URL=postgresql+asyncpg://user:password@local-db.staging.internal/news_board
LOCAL_DB_SSL=true

# ── CORS ──
# Comma-separated list of allowed origins. Wildcards ("*") are rejected at startup.
# Document the real frontend / gateway origin(s) here.
ALLOW_ORIGIN=https://app.staging.optimce.example

# ── Observability (optional in staging, required in production) ──
LOGGING_TOKEN=
LOGGING_TRACES_URL=
LOGGING_LOGS_URL=
LOGGING_METRICS_URL=
